{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'wasm-unsafe-eval' https://vercel.live https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdn.jsdelivr.net; font-src 'self' https://fonts.gstatic.com https://cdn.jsdelivr.net; img-src 'self' data:; connect-src 'self' https://cdn.jsdelivr.net https://vercel.live; manifest-src 'self'; frame-src https://vercel.live"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        },
        {
          "key": "Service-Worker-Allowed",
          "value": "/"
        }
      ]
    }
  ],
  "redirects": [
    { "source": "/dsa", "destination": "/dsa/index.html", "permanent": true },
    { "source": "/programming", "destination": "/programming/index.html", "permanent": true },
    { "source": "/python/:path*", "destination": "/programming/python/:path*", "permanent": true },
    { "source": "/python", "destination": "/programming/python/index.html", "permanent": true },
    { "source": "/sql", "destination": "/databases/index.html", "permanent": true },
    { "source": "/sql/mongodb", "destination": "/databases/mongodb.html", "permanent": true },
    { "source": "/backend", "destination": "/system-design/index.html", "permanent": true },
    { "source": "/backend/django", "destination": "/system-design/django.html", "permanent": true },
    { "source": "/backend/flask", "destination": "/system-design/flask.html", "permanent": true },
    { "source": "/backend/fastapi", "destination": "/system-design/fastapi.html", "permanent": true },
    { "source": "/git", "destination": "/devops/index.html", "permanent": true },
    { "source": "/devops", "destination": "/devops/index.html", "permanent": true },
    { "source": "/system-design", "destination": "/system-design/index.html", "permanent": true },
    { "source": "/databases", "destination": "/databases/index.html", "permanent": true },
    { "source": "/aiml", "destination": "/aiml/index.html", "permanent": true },
    { "source": "/interview", "destination": "/interview/index.html", "permanent": true },
    { "source": "/about", "destination": "/about.html", "permanent": true }
  ]
}
